---
// PoliticianCard — Shows a politician in search results
import { getInitials, formatCurrency, presenceColor } from '@lib/types';
import type { SearchResult } from '@lib/types';

export interface Props {
  result: SearchResult;
}

const { result } = Astro.props;
const { politician, presencePercent, totalAmendments } = result;
const initials = getInitials(politician.name);
const chamberLabel = politician.chamber === 'camara' ? 'Deputado(a) Federal' : 'Senador(a)';
const href = `/politico/${politician.chamber}/${politician.id}`;
---

<a class="pol-card card card--interactive" href={href}>
  <div class="pol-card__avatar">
    {
      politician.photoUrl ? (
        <img src={politician.photoUrl} alt={politician.name} class="pol-card__photo" loading="lazy" />
      ) : (
        <span class="pol-card__initials">{initials}</span>
      )
    }
  </div>
  <div class="pol-card__info">
    <div class="pol-card__name">{politician.name}</div>
    <div class="pol-card__meta">
      {politician.party} · {politician.state} · {chamberLabel}
    </div>
    <div class="pol-card__stats mono">
      <span class="pol-card__stat-dot"></span>
      <span>Presença: <strong style={`color: ${presenceColor(presencePercent)}`}>{presencePercent}%</strong></span>
      <span class="pol-card__stat-dot"></span>
      <span>Emendas: {formatCurrency(totalAmendments)}</span>
    </div>
  </div>
  <div class="pol-card__arrow mono">Ver →</div>
</a>

<style>
  .pol-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .pol-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1.5px solid var(--border-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-tertiary);
  }

  .pol-card__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pol-card__initials {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--text-secondary);
  }

  .pol-card__name {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .pol-card__meta {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .pol-card__stats {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.68rem;
    color: var(--text-secondary);
    margin-top: 3px;
  }

  .pol-card__stat-dot {
    width: 4px;
    height: 4px;
    background: var(--text-tertiary);
    border-radius: 50%;
  }

  .pol-card__arrow {
    margin-left: auto;
    flex-shrink: 0;
    font-size: 0.65rem;
    border: 1px solid var(--border-secondary);
    color: var(--text-secondary);
    padding: 3px 7px;
    border-radius: 4px;
  }
</style>
